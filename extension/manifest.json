{
  "manifest_version": 3,
  "name": "GOADS BM Invite",
  "version": "2.1.0",
  "description": "GOADS — Invite users to Business Manager via email (no sign-in required)",
  "permissions": ["activeTab", "scripting", "tabs", "cookies"],
  "host_permissions": [
    "https://*.facebook.com/*",
    "https://graph.facebook.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_icon": { "48": "icon48.png", "128": "icon128.png" }
  },
  "icons": { "48": "icon48.png", "128": "icon128.png" },
  "background": { "service_worker": "background.js" }
}
